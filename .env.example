COMPOSE_PROJECT_NAME=cabal
TZ=Asia/Shanghai

MSSQL_PID=Developer
MSSQL_PORT=1433
MSSQL_SA_PASSWORD=CHANGE_ME

# Required: address reachable by the game client.
CABAL_PUBLIC_IP=CHANGE_ME
# Required: numeric values matching the game client.
CLIENT_VERSION=CHANGE_ME
NORMAL_CLIENT_MAGIC_KEY=CHANGE_ME
AUTO_START=true

# Website: http://localhost:${WEBSITE_PORT}
WEBSITE_PORT=8080
WEBSITE_TITLE=CABAL ONLINE
WEBSITE_NAME_PRIMARY=CABAL
WEBSITE_NAME_SECONDARY=ONLINE
WEBSITE_LOGO=images/logo-vertu.png
WEBSITE_SERVER_LABEL=New Server
WEBSITE_DOWNLOAD_LABEL=Download Now!
WEBSITE_MAINTENANCE=0
WEBSITE_MAINTENANCE_UNTIL=January 24, 2026 15:30:00
# Comma-separated account IDs allowed to access administrator functions.
WEBSITE_ADMIN_USERNAMES=CHANGE_ME

WEBSITE_MSSQL_DATABASE=Account
WEBSITE_DB_ACCOUNT=Account
WEBSITE_DB_CASH=CabalCash
WEBSITE_DB_GAME=Server01
WEBSITE_DB_NETCAFE=NetcafeBilling
WEBSITE_DB_EVENT=EventData
# SQL.txt uses reygie even though the original settings.php used webdb.
WEBSITE_DB_SITE=reygie
